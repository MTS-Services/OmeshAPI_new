// schema.prisma
// =============================================================
// Sports Event Management Platform — Prisma schema
// Derived strictly from the existing React frontend (omesh)
// =============================================================

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// -----------------------------------------------------------------
// ENUMS
// -----------------------------------------------------------------

enum Role {
  ADMIN
  ORGANIZER
  USER
}

enum AccountStatus {
  ACTIVE
  PENDING_VERIFICATION
  SUSPENDED
  DEACTIVATED
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum EventStatus {
  DRAFT
  PENDING // organizer submitted, awaiting admin review (Requested)
  APPROVED // approved by admin
  UPCOMING // approved + future date (derived; persisted for filtering)
  ONGOING
  COMPLETED
  REJECTED
  SUSPENDED
  CANCELLED
}

enum RegistrationStatus {
  PENDING_PAYMENT
  CONFIRMED
  CANCELLED
  REFUNDED
  ATTENDED
  NO_SHOW
}

enum PaymentStatus {
  PENDING
  SUCCEEDED
  FAILED
  REFUNDED
}

enum PaymentMethod {
  PAYPAL
  BANK
  CARD
  MANUAL
}

enum PayoutStatus {
  REQUESTED
  APPROVED
  REJECTED
  PAID
}

enum ToolkitRequestStatus {
  SUBMITTED
  IN_REVIEW
  QUOTED
  IN_PROGRESS
  DELIVERED
  CANCELLED
}

enum TrainingCategory {
  FIVE_K // "5K"
  TEN_K // "10K"
}

enum TrainingEnrollmentStatus {
  ACTIVE
  COMPLETED
  DROPPED
}

enum OtpPurpose {
  EMAIL_VERIFICATION
  PASSWORD_RESET
  LOGIN_2FA
}

enum NotificationType {
  EVENT_APPROVED
  EVENT_REJECTED
  EVENT_SUSPENDED
  REGISTRATION_CONFIRMED
  PAYOUT_APPROVED
  PAYOUT_REJECTED
  TOOLKIT_UPDATE
  GENERIC
}

// -----------------------------------------------------------------
// AUTH / USERS
// -----------------------------------------------------------------

model User {
  id            String        @id @default(cuid())
  fullName      String
  email         String        @unique
  phone         String?
  passwordHash  String
  avatarUrl     String?
  role          Role          @default(USER)
  status        AccountStatus @default(PENDING_VERIFICATION)
  emailVerified Boolean       @default(false)
  joinedAt      DateTime      @default(now())
  lastLoginAt   DateTime?

  // Profile fields used by UserDashboard / RegisterView / Checkout
  gender      Gender?
  dateOfBirth DateTime?
  location    String?
  teamClub    String?

  // Relations
  organizerProfile    OrganizerProfile?
  organizedEvents     Event[]              @relation("EventsByOrganizer")
  registrations       Registration[]
  trainingEnrollments TrainingEnrollment[]
  toolkitRequests     ToolkitRequest[]
  payouts             PayoutRequest[]
  notifications       Notification[]
  otpTokens           OtpToken[]
  sessions            Session[]
  reviewedEvents      EventReview[]        @relation("EventsReviewedByAdmin")
  reviewedPayouts     PayoutRequest[]      @relation("PayoutsReviewedByAdmin")
  reviewedToolkits    ToolkitRequest[]     @relation("ToolkitsReviewedByAdmin")

  createdAt  DateTime    @default(now())
  updatedAt  DateTime    @updatedAt
  promoCodes PromoCode[]

  @@index([role, status])
}

model OrganizerProfile {
  id     String @id @default(cuid())
  userId String @unique
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  organizationName String?
  bio              String?
  website          String?
  // Earnings ledger snapshot (also derivable from Payment/Payout aggregates)
  availableBalance Decimal @default(0) @db.Decimal(12, 2)
  pendingBalance   Decimal @default(0) @db.Decimal(12, 2)
  manualBalance    Decimal @default(0) @db.Decimal(12, 2)
  manualCount      Decimal @default(0) @db.Decimal(12, 2)
  totalEarnings    Decimal @default(0) @db.Decimal(12, 2)

  payoutAccounts PayoutAccount[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Session {
  id           String    @id @default(cuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  refreshToken String    @unique
  userAgent    String?
  ipAddress    String?
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  @@index([userId])
}

model OtpToken {
  id         String     @id @default(cuid())
  userId     String
  user       User       @relation(fields: [userId], references: [id], onDelete: Cascade)
  codeHash   String
  purpose    OtpPurpose
  expiresAt  DateTime
  consumedAt DateTime?
  createdAt  DateTime   @default(now())

  @@index([userId, purpose])
}

// -----------------------------------------------------------------
// EVENTS
// -----------------------------------------------------------------

model Event {
  id            String      @id @default(cuid())
  slug          String      @unique
  title         String
  coverImageUrl String?
  flag          Boolean     @default(false) // featured flag from frontend
  status        EventStatus @default(PENDING)

  // Schedule & location
  startAt  DateTime
  endAt    DateTime?
  time     String?
  timezone String    @default("UTC")
  location String
  distance String? // e.g. "5km", "10km"
  country  String

  // Pricing & capacity
  price          Decimal @default(0) @db.Decimal(10, 2)
  currency       String  @default("USD")
  totalSeats     Int     @default(0)
  availableSeats Int     @default(0)
  registerClose  Boolean @default(false)
  complete       Boolean @default(false)

  // Rich description (matches public/data eventDetails.json shape)
  headline        String?
  body            String?  @db.Text
  sortDescription String?  @db.Text
  tagline         String?
  bulletsTop      String[] // bullets1
  bulletsBottom   String[] // bullets2
  tShirtIncluded  Boolean  @default(false)
  tShirtSizes     String[] // e.g. ["S", "M", "L"]
  tShirtPrice     Decimal  @default(0) @db.Decimal(10, 2)
  isFree          Boolean  @default(false)
  tShirtImageUrl  String[]
  promoCode       String?

  // Relations
  organizerId String
  organizer   User   @relation("EventsByOrganizer", fields: [organizerId], references: [id])

  images        EventImage[]
  registrations Registration[]
  reviews       EventReview[]
  payments      Payment[]
  notifications Notification[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, startAt])
  @@index([organizerId])
}

model EventImage {
  id       String @id @default(cuid())
  eventId  String
  event    Event  @relation(fields: [eventId], references: [id], onDelete: Cascade)
  url      String
  position Int    @default(0)

  @@index([eventId, position])
}

// Audit trail for admin approvals/rejections/suspensions
model EventReview {
  id         String      @id @default(cuid())
  eventId    String
  event      Event       @relation(fields: [eventId], references: [id], onDelete: Cascade)
  reviewerId String
  reviewer   User        @relation("EventsReviewedByAdmin", fields: [reviewerId], references: [id])
  fromStatus EventStatus
  toStatus   EventStatus
  note       String?
  createdAt  DateTime    @default(now())

  @@index([eventId, createdAt])
}

// -----------------------------------------------------------------
// REGISTRATIONS / CHECKOUT
// -----------------------------------------------------------------

model Registration {
  id      String  @id @default(cuid())
  eventId String
  event   Event   @relation(fields: [eventId], references: [id], onDelete: Cascade)
  userId  String? // null when admin/organizer adds participant manually
  user    User?   @relation(fields: [userId], references: [id])

  batchId String

  // Participant snapshot (Checkout form)
  firstName          String
  lastName           String
  email              String
  phone              String?
  gender             Gender?
  age                Int?
  dateOfBirth        DateTime?
  location           String?
  teamClub           String?
  selectedTShirtSize String?
  couponCode         String?
  buyTShirt          Boolean   @default(false)

  status RegistrationStatus @default(PENDING_PAYMENT)
  source String             @default("ONLINE") // ONLINE | MANUAL_ADD

  payment Payment? @relation(fields: [paymentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  paymentId String?

  // @@unique([eventId, email])
  @@index([eventId, status])
  @@index([userId])
}

// -----------------------------------------------------------------
// PAYMENTS, PROMO CODES, PLATFORM SETTINGS
// -----------------------------------------------------------------

model Payment {
  id      String @id @default(cuid())
  // registrationId String       @unique
  // registration   Registration @relation(fields: [registrationId], references: [id], onDelete: Cascade)
  batchId String @unique
  eventId String
  event   Event  @relation(fields: [eventId], references: [id])

  subtotal      Decimal @db.Decimal(10, 2)
  processingFee Decimal @db.Decimal(10, 2) // = subtotal * platformFeePct
  discount      Decimal @default(0) @db.Decimal(10, 2)
  total         Decimal @db.Decimal(10, 2)
  currency      String  @default("USD")

  method      PaymentMethod?
  status      PaymentStatus  @default(PENDING)
  providerRef String? // gateway transaction id
  promoCodeId String?
  promoCode   PromoCode?     @relation(fields: [promoCodeId], references: [id])

  paidAt        DateTime?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  registrations Registration[]

  @@index([eventId, status])
}

model PromoCode {
  id            String    @id @default(cuid())
  code          String    @unique
  description   String?
  // Either flat amount or percentage discount
  // amountOff      Decimal?  @db.Decimal(10, 2)
  // percentOff     Decimal?  @db.Decimal(5, 2)
  // maxRedemptions Int?
  userid        String
  user          User      @relation(fields: [userid], references: [id])
  redeemedCount Int       @default(0)
  startsAt      DateTime?
  expiresAt     DateTime?
  isActive      Boolean   @default(true)

  payments      Payment[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  allowedEmails AllowedEmail[]
}

model AllowedEmail {
  id          String    @id @default(cuid())
  email       String
  promoCodeId String
  promoCode   PromoCode @relation(fields: [promoCodeId], references: [id], onDelete: Cascade)

  @@unique([email, promoCodeId])
}

// Singleton row managed by admin SettingsView
model PlatformSetting {
  id             Int      @id @default(1)
  platformFeePct Decimal  @default(6) @db.Decimal(5, 2) // 0..20
  currency       String   @default("USD")
  updatedById    String?
  updatedAt      DateTime @updatedAt
}

// -----------------------------------------------------------------
// PAYOUTS
// -----------------------------------------------------------------

model PayoutAccount {
  id                 String           @id @default(cuid())
  organizerProfileId String
  organizerProfile   OrganizerProfile @relation(fields: [organizerProfileId], references: [id], onDelete: Cascade)
  method             PaymentMethod // PAYPAL | BANK
  label              String? // user-friendly name
  // Generic JSON envelope so PayPal email or bank details both fit
  details            Json
  isDefault          Boolean          @default(false)
  createdAt          DateTime         @default(now())

  payouts PayoutRequest[]

  @@index([organizerProfileId])
}

model PayoutRequest {
  id          String         @id @default(cuid())
  organizerId String
  organizer   User           @relation(fields: [organizerId], references: [id])
  accountId   String?
  account     PayoutAccount? @relation(fields: [accountId], references: [id])

  amount        Decimal       @db.Decimal(12, 2)
  currency      String        @default("USD")
  accountNumber String? // for manual payments
  method        PaymentMethod
  status        PayoutStatus  @default(REQUESTED)

  reviewedById String?
  reviewedBy   User?     @relation("PayoutsReviewedByAdmin", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?
  paidAt       DateTime?
  note         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([organizerId, status])
}

// -----------------------------------------------------------------
// TRAINING PLANS
// -----------------------------------------------------------------

model TrainingPlanCategory {
  id          String @id @default(cuid())
  plan        String
  slug        String @unique
  description String

  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  trainingPlans TrainingPlan[]
}

model TrainingPlan {
  id          String               @id @default(cuid())
  categoryId  String
  category    TrainingPlanCategory @relation(fields: [trainingPlanCategoryId], references: [id])
  durationMin String          
  title       String
  description String               @db.Text
  isActive    Boolean              @default(true)

  weeks       TrainingWeek[]
  enrollments TrainingEnrollment[]

  createdAt              DateTime @default(now())
  updatedAt              DateTime @updatedAt
  trainingPlanCategoryId String

  @@unique([durationMin])
}

model TrainingWeek {
  id     String       @id @default(cuid())
  planId String
  plan   TrainingPlan @relation(fields: [planId], references: [id], onDelete: Cascade)
  weekNo Int
  days   String[]

  @@unique([planId, weekNo])
}

model TrainingEnrollment {
  id          String                   @id @default(cuid())
  planId      String
  plan        TrainingPlan             @relation(fields: [planId], references: [id], onDelete: Cascade)
  userId      String
  user        User                     @relation(fields: [userId], references: [id])
  status      TrainingEnrollmentStatus @default(ACTIVE)
  startedAt   DateTime                 @default(now())
  completedAt DateTime?

  @@unique([planId, userId])
  @@index([userId, status])
}

// -----------------------------------------------------------------
// TOOLKIT (Custom quote requests)
// -----------------------------------------------------------------

// Static "How it works" steps (4 cards) — admin/CMS managed
model ToolkitStep {
  id          String @id @default(cuid())
  position    Int    @unique
  icon        String // lucide icon name (Lightbulb, FileEdit, ...)
  title       String
  description String
}

model ToolkitRequest {
  id          String  @id @default(cuid())
  // Submitter (organizer) — optional to allow anonymous submissions
  submitterId String?
  submitter   User?   @relation(fields: [submitterId], references: [id])

  // Event details
  eventName String
  eventDate DateTime?
  quantity  Int

  // Design
  designImageUrls String[]
  needsDesignHelp Boolean  @default(false)

  // Contact info (mirrors form)
  fullName String
  email    String
  phone    String?

  status        ToolkitRequestStatus @default(SUBMITTED)
  quoteAmount   Decimal?             @db.Decimal(12, 2)
  quoteCurrency String               @default("USD")
  adminNote     String?

  reviewedById String?
  reviewedBy   User?     @relation("ToolkitsReviewedByAdmin", fields: [reviewedById], references: [id])
  reviewedAt   DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status, createdAt])
}

// -----------------------------------------------------------------
// NOTIFICATIONS (used by admin actions, payouts, registrations)
// -----------------------------------------------------------------

model Notification {
  id        String           @id @default(cuid())
  userId    String
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  type      NotificationType
  title     String
  message   String           @db.Text
  // Optional FK to an event for "EVENT_*" notifications
  eventId   String?
  event     Event?           @relation(fields: [eventId], references: [id])
  readAt    DateTime?
  createdAt DateTime         @default(now())

  @@index([userId, readAt])
}
